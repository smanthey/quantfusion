# Database
DATABASE_URL=your_database_url_here

# Trading Mode (backtest | live | paper)
MODE=paper

# OpenClaw automation mode (paper | live)
OPENCLAW_TRADING_MODE=paper
OPENCLAW_DEFAULT_RISK_PCT=1
OPENCLAW_MAX_NOTIONAL_PCT=5
OPENCLAW_LIVE_CONFIRM_TTL_MS=600000

# TradingView webhook auth
TRADINGVIEW_WEBHOOK_SECRET=replace_with_random_secret

# OpenAlgo broker adapter (required for live orders)
OPENALGO_API_URL=https://your-openalgo-endpoint/orders
OPENALGO_API_KEY=your_openalgo_api_key

# Binance API Keys
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Alpaca API Keys (if using)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
CORS_ORIGIN=https://tradingbit.replit.app
SESSION_SECRET=your_session_secret_here

# Risk Management
MAX_DAILY_LOSS=200
MAX_POSITION_SIZE=1000
MAX_TOTAL_EXPOSURE=0.30

# Rate Limiting
BINANCE_RATE_LIMIT=1200

# Alternative data scanners (disabled by default)
ENABLE_POLITICIAN_SCANNER_LIVE=false
QUIVER_API_KEY=your_quiver_api_key
QUIVER_CONGRESS_TRADES_URL=https://api.quiverquant.com/beta/live/congresstrading

ENABLE_OPTIONS_SCANNER_LIVE=false
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key
UNUSUAL_WHALES_OPTIONS_URL=https://api.unusualwhales.com/api/options/flow/recent

ENABLE_WHALE_SCANNER_LIVE=false
WHALE_ALERT_API_KEY=your_whale_alert_api_key
WHALE_ALERT_URL=https://api.whale-alert.io/v1/transactions
